# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Owner detection (at least one required for admin access)
OWNER_EMAIL=owner@example.com
NEXT_PUBLIC_OWNER_EMAIL=owner@example.com

# AI Providers (optional — at least one needed for AI Coach)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...

# CoinGecko (required for market data)
CG_DEMO_API_KEY=CG-...

# Upstash Redis (required for production rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token
